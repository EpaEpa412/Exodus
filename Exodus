    <h1 style="font-size:24px;color:#ff4422;">파라오에게 잡혔다!</h1><h2 style="color:#ff6644;">CAPTURED</h2>
    <p>이동 거리: <span id="osc" style="color:#f0c040">0</span></p>
    <p>최고 기록: <span id="bsc" style="color:#f0c040">0</span></p>
    <button class="btn" id="rtb">다시 탈출</button>
    <div class="verse">"두려워하지 말라 오직 믿고 가라" — 출애굽기 14:13</div>
  </div>
</div>
<script>
// ══ CONSTANTS ══
const TARGET=5000, BOSS_AT=[1050,3050], LY=[30,46], G=0.58, JV=-12, IDUR=70;

// ══ DOM ══
const gc=document.getElementById('gc'), bgEl=document.getElementById('bg'), groundEl=document.getElementById('ground');
const player=document.getElementById('player'), od=document.getElementById('od');
const scEl=document.getElementById('sc'), pwEl=document.getElementById('pw'), lvEl=document.getElementById('lv'), pfEl=document.getElementById('pf');
const dhi=document.getElementById('dhi'), dlo=document.getElementById('dlo');
const poEl=document.getElementById('po'), plblEl=document.getElementById('plbl');
const pharaoh=document.getElementById('pharaoh'), baEl=document.getElementById('ba');
const geEl=document.getElementById('ge'), sbEl=document.getElementById('sb'), ceEl=document.getElementById('ce');
const bls=[0,1,2,3,4].map(i=>document.getElementById('bl'+i));

// ══ STARS ══
const sd=document.getElementById('strs'); sd.style.cssText='position:absolute;top:0;left:0;right:0;height:45%;overflow:hidden;';
for(let i=0;i<55;i++){const s=document.createElement('div');s.className='star';const z=Math.random()*2.5+.5;s.style.cssText=`width:${z}px;height:${z}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-delay:${Math.random()*3}s;animation-duration:${1.5+Math.random()*2}s;`;sd.appendChild(s);}

// ══ STATE ══
let gs='idle', score=0, best=0, lives=3, spd=2.5, frm=0, raf=null;
let px=100,py=0,vy=0,jl=2, lane=0, slid=false, slidT=0, inv=0;
let hasPow=false, powT=0, gpT=0, gT=0;
let obs=[], heals=[], nHeal=600+ri(400), spT=0, spI=90;
let stg=0, pyrOff=0;
let plagOn=false, plagT=0, plagTy='', nPlag=450;
let bossOn=false, bossX=0, bossP=0, bossT=0, bBuls=[], bIdx=0;
const keys={}, mob={jmp:false,sld:false};
function ri(n){return Math.floor(Math.random()*n);}
function rf(a,b){return a+Math.random()*(b-a);}

// ══ INPUT ══
document.addEventListener('keydown',e=>{
  if(keys[e.code])return; keys[e.code]=true;
  if(gs!=='playing')return;
  if(['ArrowUp','Space','KeyW'].includes(e.code)){doJump();e.preventDefault();}
  if(['ArrowDown','KeyS'].includes(e.code)){startSlide();e.preventDefault();}
});
document.addEventListener('keyup',e=>{
  keys[e.code]=false;
  if(['ArrowDown','KeyS'].includes(e.code)&&slid)endSlide();
});
document.getElementById('mjp').addEventListener('touchstart',e=>{if(gs==='playing')doJump();e.preventDefault();},{passive:false});
document.getElementById('msld').addEventListener('touchstart',e=>{mob.sld=true;if(gs==='playing')startSlide();e.preventDefault();},{passive:false});
document.getElementById('msld').addEventListener('touchend',e=>{mob.sld=false;endSlide();e.preventDefault();},{passive:false});

function doJump(){if(jl>0&&!slid){vy=JV;jl--;}}
function startSlide(){
  if(py>8){vy=Math.max(vy,9);return;}
  if(slid)return;
  slid=true;slidT=55;player.classList.add('sliding');
}
function endSlide(){slid=false;slidT=0;player.classList.remove('sliding');}

// ══ MUSIC ══
let actx=null,mOn=true,mPlay=false,mNodes=[],dInt=null,mTmr=null,bTmr=null;
const SC=[73.42,77.78,92.50,98,110,116.54,130.81,146.83], SCH=SC.map(f=>f*2);
const BPM=84,BT=60/BPM;
function gAc(){if(!actx)actx=new(window.AudioContext||window.webkitAudioContext)();if(actx.state==='suspended')actx.resume();return actx;}
function pTone(f,tp,g,t,d,dt=0){const c=gAc(),o=c.createOscillator(),gn=c.createGain(),fl=c.createBiquadFilter();o.type=tp;o.frequency.setValueAtTime(f,t);o.detune.setValueAtTime(dt,t);fl.type='lowpass';fl.frequency.setValueAtTime(1200,t);gn.gain.setValueAtTime(0,t);gn.gain.linearRampToValueAtTime(g,t+.02);gn.gain.exponentialRampToValueAtTime(.001,t+d);o.connect(fl);fl.connect(gn);gn.connect(c.destination);o.start(t);o.stop(t+d+.05);mNodes.push(o);}
function drum(tp,t){const c=gAc();if(tp==='kick'){const o=c.createOscillator(),g=c.createGain();o.frequency.setValueAtTime(120,t);o.frequency.exponentialRampToValueAtTime(40,t+.15);g.gain.setValueAtTime(.8,t);g.gain.exponentialRampToValueAtTime(.001,t+.3);o.connect(g);g.connect(c.destination);o.start(t);o.stop(t+.35);mNodes.push(o);}else{const b=c.createBuffer(1,c.sampleRate*.1,c.sampleRate),d=b.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,tp==='snap'?8:3);const s=c.createBufferSource(),g=c.createGain(),fl=c.createBiquadFilter();fl.type=tp==='snap'?'bandpass':'highpass';fl.frequency.value=tp==='snap'?1200:3000;fl.Q.value=2;s.buffer=b;g.gain.setValueAtTime(tp==='snap'?.45:.2,t);g.gain.exponentialRampToValueAtTime(.001,t+.1);s.connect(fl);fl.connect(g);g.connect(c.destination);s.start(t);s.stop(t+.2);mNodes.push(s);}}
function dBar(t){[[0,'kick'],[BT*.5,'snap'],[BT*.75,'shake'],[BT,'snap'],[BT*1.5,'kick'],[BT*1.75,'shake'],[BT*2,'snap'],[BT*2.5,'snap'],[BT*2.75,'shake'],[BT*3,'kick'],[BT*3.5,'snap'],[BT*3.75,'shake']].forEach(([dt,tp])=>drum(tp,t+dt));}
const MOT=[{d:7,r:.8},{d:6,r:.4},{d:4,r:.6},{d:2,r:.4},{d:1,r:.5},{d:0,r:1.2},{d:2,r:.4},{d:4,r:.6}];
function sMel(t){if(!mPlay)return;let c=t;MOT.forEach(({d,r})=>{pTone(SCH[d%8],'sine',.22,c,r*.85,Math.random()*4-2);c+=r*BT;});const tot=MOT.reduce((s,n)=>s+n.r,0)*BT,rest=BT*(4+ri(4));mTmr=setTimeout(()=>sMel(c+rest-tot),(tot+rest-.1)*1000);}
function sBass(t){if(!mPlay)return;[SC[0],SC[4],SC[0],SC[3]].forEach((f,i)=>{pTone(f,'sawtooth',.18,t+i*BT,BT*1.1);pTone(f*.5,'sine',.12,t+i*BT,BT*1.1);});const bl=BT*4;bTmr=setTimeout(()=>sBass(t+bl),(bl-.1)*1000);}
function startMus(){if(mPlay||!mOn)return;mPlay=true;const c=gAc(),now=c.currentTime+.1;const bl=BT*4;let nb=now;dBar(nb);dInt=setInterval(()=>{if(!mPlay){clearInterval(dInt);return;}nb+=bl;dBar(nb);},bl*1000-50);sBass(now);setTimeout(()=>sMel(gAc().currentTime+.5),1000);}
function stopMus(){mPlay=false;clearInterval(dInt);clearTimeout(mTmr);clearTimeout(bTmr);mNodes.forEach(n=>{try{n.stop();}catch(e){}});mNodes=[];}
let mbOn=true;
document.getElementById('mbt').addEventListener('click',()=>{mbOn=!mbOn;mOn=mbOn;document.getElementById('mbt').textContent=mbOn?'🎵':'🔇';if(mbOn&&gs==='playing')startMus();else stopMus();});

// ══ STAGE ══
const BGCL=['bg0','bg1','bg2','bg3','bg4'], GCL=['g0','g1','g2','g3','g4'];
const SLBL=['🏺 이집트 — 병사와 풍뎅이','🌵 광야 — 창병과 바위','⛰️ 시내산 — 독사와 낙석','🔥 모압 — 기마병과 화살','🌊 홍해 앞 — 파라오 정예군'];
function setStage(s){stg=s;bgEl.className=BGCL[s];groundEl.className=GCL[s];bls.forEach((l,i)=>l.classList.toggle('vis',i===s));showBanner(SLBL[s]);}
function showBanner(t){sbEl.textContent=t;sbEl.style.opacity='1';setTimeout(()=>sbEl.style.opacity='0',2600);}

// ══ HUD ══
function updHUD(){scEl.textContent=score;lvEl.textContent='❤️'.repeat(lives)+'🖤'.repeat(3-lives);pwEl.style.display=hasPow?'block':'none';pfEl.style.width=Math.min(score/TARGET*100,100)+'%';dhi.classList.toggle('on',lane===1);dlo.classList.toggle('on',lane===0);}

// ══ SPAWN ══
function spawnObs(){
  const r=Math.random(), ln=(score>500&&Math.random()<.35)?1:0, lb=LY[ln], sw=window.innerWidth+60;
  let tp;
  if(stg===0) tp=r<.07?'cross':r<.55?'soldier':'scarab';
  else if(stg===1) tp=r<.07?'cross':r<.42?'spear':r<.72?'scarab_hi':'rock';
  else if(stg===2) tp=r<.07?'cross':r<.42?'snake':r<.72?'boulder':'dark_sol';
  else if(stg===3) tp=r<.07?'cross':r<.47?'rider':r<.77?'arrow':'fireball';
  else tp=r<.07?'cross':r<.45?'elite_sol':r<.78?'spear_fast':'wave';

  if(tp==='cross'){
    const el=document.createElement('div');el.className='cw';
    el.innerHTML='<div class="ci"></div>';
    el.style.cssText=`position:absolute;left:${sw}px;bottom:${LY[0]+4}%;width:30px;height:38px;`;
    od.appendChild(el);obs.push({el,x:sw,tp:'cross',lane:-1,w:30,h:9999,cross:true});return;
  }
  const el=document.createElement('div');el.className='obs';el.style.position='absolute';
  el.style.bottom=lb+'%';el.style.left=sw+'px';
  let w=28,h=50,ex={};
  if(tp==='soldier'){el.innerHTML='<div class="sh"></div><div class="sd"></div><div class="sb"></div><div class="sp"><div class="spt"></div></div>';el.style.width='28px';el.style.height='50px';w=28;h=50;}
  else if(tp==='elite_sol'){el.innerHTML='<div class="sh" style="background:#f0c040;width:20px;height:13px;"></div><div class="sd"></div><div class="sb" style="background:linear-gradient(180deg,#c4960a,#8b6914);width:24px;height:34px;"></div><div class="sp" style="height:54px;"><div class="spt"></div></div>';el.style.width='30px';el.style.height='55px';w=30;h=55;}
  else if(tp==='scarab'){el.innerHTML='<div class="swl"></div><div class="scb"></div><div class="swr"></div>';el.style.width='36px';el.style.height='28px';w=36;h=28;}
  else if(tp==='scarab_hi'){el.innerHTML='<div class="swl"></div><div class="scb"></div><div class="swr"></div>';el.style.bottom=(lb+12+Math.random()*10)+'%';el.style.width='36px';el.style.height='28px';el.style.filter='drop-shadow(0 0 6px #ff440066)';od.appendChild(el);obs.push({el,x:sw,tp:'scarab',lane:ln,w:36,h:28,slide:true});return;}
  else if(tp==='spear'||tp==='spear_fast'){el.className='obs sprj';el.style.bottom=(LY[0]+2)+'%';el.style.width='44px';el.style.height='5px';od.appendChild(el);obs.push({el,x:sw,tp:'spear',lane:0,w:44,h:12,boost:tp==='spear_fast'?2.5:0});return;}
  else if(tp==='arrow'){el.className='obs sprj';el.style.cssText+=`width:32px;height:4px;background:linear-gradient(90deg,#8b5e1a,#c0a060);`;el.style.bottom=(LY[ln]+3+Math.random()*8)+'%';od.appendChild(el);obs.push({el,x:sw,tp:'spear',lane:ln,w:32,h:10,boost:2});return;}
  else if(tp==='rock'){el.style.cssText+=`width:50px;height:36px;background:linear-gradient(160deg,#5a4a2a,#3a2a10);border-radius:40% 60% 0 0/60% 40% 0 0;`;w=50;h=36;}
  else if(tp==='boulder'){el.style.cssText+=`width:44px;height:44px;background:radial-gradient(circle at 35% 35%,#6a5a4a,#2a1e14);border-radius:50%;box-shadow:2px 3px 8px #0008;`;w=44;h=44;}
  else if(tp==='snake'){el.style.cssText+=`width:38px;height:14px;background:linear-gradient(90deg,#2a5a1a,#1a3a0a);border-radius:8px 2px 2px 8px;`;el.innerHTML='<div style="position:absolute;left:-4px;top:1px;width:8px;height:10px;background:#3a7a2a;border-radius:50% 50% 20% 20%;"></div>';w=38;h=14;}
  else if(tp==='dark_sol'){el.innerHTML='<div class="sh" style="background:#1a1a2a;"></div><div class="sd" style="background:#2a1a0a;"></div><div class="sb" style="background:linear-gradient(180deg,#1a1a3a,#0a0a1a);"></div><div class="sp" style="background:#3a3a3a;"><div class="spt" style="border-bottom-color:#8888aa;"></div></div>';el.style.width='28px';el.style.height='50px';w=28;h=50;}
  else if(tp==='rider'){el.innerHTML='<div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:34px;height:28px;background:linear-gradient(180deg,#8b3a00,#5a2000);border-radius:4px 4px 0 0;"></div><div style="position:absolute;bottom:26px;left:50%;transform:translateX(-50%);width:16px;height:16px;background:#c4865a;border-radius:50%;border:2px solid #c4960a;"></div><div style="position:absolute;bottom:-2px;left:50%;transform:translateX(-50%);width:44px;height:18px;background:linear-gradient(180deg,#6b4010,#4a2a08);border-radius:30% 30% 0 0;"></div>';el.style.width='44px';el.style.height='46px';w=44;h=46;}
  else if(tp==='fireball'){el.style.bottom=(lb+8+Math.random()*8)+'%';el.style.cssText+=`width:22px;height:22px;background:radial-gradient(circle,#ffee00,#ff6600,#cc2200);border-radius:50%;box-shadow:0 0 16px #ff6600aa;`;od.appendChild(el);obs.push({el,x:sw,tp:'fireball',lane:ln,w:22,h:22,slide:true});return;}
  else if(tp==='wave'){el.style.cssText+=`width:55px;height:30px;background:linear-gradient(180deg,#1a6699,#0a3d5c);border-radius:50% 50% 0 0;box-shadow:0 0 10px #1a669966;`;w=55;h=30;}
  od.appendChild(el);obs.push({el,x:sw,tp,lane:ln,w,h,...ex});
}

// ══ HEAL (메추라기) ══
function spawnHeal(){
  const el=document.createElement('div');el.className='qi';
  el.style.cssText=`position:absolute;left:${window.innerWidth+60}px;bottom:${LY[0]+5}%;`;
  el.innerHTML='<div style="position:absolute;bottom:4px;left:50%;transform:translateX(-50%);width:18px;height:12px;background:linear-gradient(135deg,#c4865a,#8b5e3a);border-radius:50% 50% 40% 40%;"></div><div style="position:absolute;bottom:14px;left:50%;transform:translateX(-50%);width:10px;height:10px;background:#c4865a;border-radius:50%;"></div><div style="position:absolute;bottom:16px;right:2px;width:8px;height:5px;background:#d49a6a;border-radius:0 50% 50% 0;transform:rotate(-20deg);"></div><div style="position:absolute;bottom:4px;left:2px;width:3px;height:5px;background:#c4960a;border-radius:1px;"></div>';
  gc.appendChild(el);heals.push({el,x:window.innerWidth+60});
}

// ══ PLAGUE ══
const PLAGUES=[{id:'locust',lbl:'🦗 메뚜기 재앙! — 높이 점프 금지!',cl:'pl'},{id:'dark',lbl:'🌑 흑암 재앙! — 조심하라!',cl:'pd'},{id:'hail',lbl:'🧊 우박 재앙!',cl:'ph'}];
function trigPlague(){
  plagOn=true;plagT=180;
  const p=PLAGUES[ri(PLAGUES.length)];plagTy=p.id;
  poEl.className=p.cl;poEl.style.opacity='1';
  plblEl.textContent=p.lbl;plblEl.style.opacity='1';
  setTimeout(()=>plblEl.style.opacity='0',2200);
  if(plagTy==='locust')spawnLocust();
}
function endPlague(){plagOn=false;plagTy='';poEl.style.opacity='0';poEl.className='';}
function spawnLocust(){
  const ch=gc.offsetHeight, bpct=76;
  const gPx=ch*LY[0]/100, lPx=ch*bpct/100, thr=lPx-gPx-22;
  const sp=28, cnt=Math.ceil(window.innerWidth/sp)+6, sx=window.innerWidth+20;
  for(let c=0;c<cnt;c++){
    const el=document.createElement('div');
    el.style.cssText=`position:absolute;left:${sx+c*sp}px;bottom:${bpct}%;width:20px;height:14px;background:#6a5800;border-radius:50% 50% 40% 40%;box-shadow:0 0 5px #c8a800;z-index:8;`;
    el.innerHTML='<div style="position:absolute;top:-4px;left:1px;width:7px;height:6px;background:#9a8400;border-radius:50%;animation:scW .13s infinite alternate;"></div><div style="position:absolute;top:-4px;right:1px;width:7px;height:6px;background:#9a8400;border-radius:50%;animation:scW .13s .07s infinite alternate;"></div>';
    od.appendChild(el);obs.push({el,x:sx+c*sp,tp:'locust',lane:-1,w:20,h:0,locust:true,thr});
  }
}
function spawnHail(){
  for(let i=0;i<3+ri(3);i++){
    const el=document.createElement('div');const dur=.4+Math.random()*.35;
    el.style.cssText=`position:absolute;z-index:89;pointer-events:none;left:${Math.random()*100}%;top:-14px;width:${5+Math.random()*5}px;height:${10+Math.random()*8}px;background:linear-gradient(180deg,#eef8ff,#88bbdd);border-radius:4px 4px 2px 2px;box-shadow:0 0 6px #aaddff66;animation:hailFall ${dur}s linear forwards;`;
    gc.appendChild(el);setTimeout(()=>{try{gc.removeChild(el);}catch(e){}},800);
  }
}

// ══ BOSS ══
function startBoss(){bossOn=true;bossP=1;bossT=0;bossX=window.innerWidth+20;pharaoh.style.display='block';pharaoh.style.left=bossX+'px';baEl.classList.add('on');setTimeout(()=>baEl.classList.remove('on'),2200);}
function updBoss(){
  bossT++;const TGT=window.innerWidth*.82;
  if(bossP===1){bossX-=spd*.9;pharaoh.style.left=bossX+'px';if(bossX<TGT){bossP=2;bossT=0;}}
  else if(bossP===2){pharaoh.style.left=TGT+'px';const iv=bossT<300?45:25;if(bossT%iv===0)spawnBul();if(bossT>600)bossP=3;}
  else{bossX+=spd*1.5;pharaoh.style.left=bossX+'px';if(bossX>window.innerWidth+100){bossOn=false;pharaoh.style.display='none';bBuls.forEach(b=>b.el.remove());bBuls=[];}}
}
function spawnBul(){
  const el=document.createElement('div');const sx=window.innerWidth*.82-20,tl=Math.random()<.5?0:1,sz=10+ri(7);
  el.style.cssText=`position:absolute;left:${sx}px;bottom:${LY[tl]+8}%;width:${sz}px;height:${sz}px;background:radial-gradient(circle,#ffcc00,#ff4400);border-radius:50%;box-shadow:0 0 ${sz+4}px #ff6600;z-index:21;`;
  gc.appendChild(el);bBuls.push({el,x:sx,spd:6+Math.random()*3+(bossT>300?2:0),lane:tl});
}

// ══ GOD EFFECT ══
function showGod(){geEl.style.display='block';const t=geEl.querySelector('.gtx');if(t){t.style.opacity='1';t.style.transition='opacity .3s';}gT=120;}
function hideGod(){geEl.style.display='none';player.classList.remove('powered');geEl.querySelectorAll('.gp').forEach(p=>p.remove());}
function spawnGP(){const p=document.createElement('div');p.className='gp';const sz=3+Math.random()*5,dur=1.2+Math.random()*1.5;p.style.cssText=`left:${20+Math.random()*(window.innerWidth-40)}px;top:${5+Math.random()*20}%;width:${sz}px;height:${sz}px;animation-duration:${dur}s;background:${Math.random()>.5?'#d4a0ff':'#fff'};box-shadow:0 0 ${sz*2}px #a060ff;`;geEl.appendChild(p);setTimeout(()=>p.remove(),dur*1000);}

// ══ MISC EFFECTS ══
function flash(c='#fff'){const f=document.createElement('div');f.className='flash';f.style.background=c;gc.appendChild(f);setTimeout(()=>f.remove(),300);}
function spawnDust(x){const d=document.createElement('div');d.className='dust';d.style.left=x+'px';d.style.bottom='30%';gc.appendChild(d);setTimeout(()=>d.remove(),600);}

// ══ WIN ══
function showWin(){
  gs='win';stopMus();ceEl.style.display='block';
  flash('#fffde0');setTimeout(()=>flash('#fff8c0'),300);
  try{const c=gAc(),now=c.currentTime;[[146.83,0],[220,.15],[293.66,.3],[369.99,.45],[440,.6],[587.33,.9]].forEach(([f,t])=>pTone(f,'sine',.3,now+t,2.5-t*.3));pTone(73.42,'sine',.2,now,5);pTone(36.71,'sine',.15,now,6);}catch(e){}
  for(let i=0;i<40;i++)setTimeout(()=>spawnCP(),i*80);
  const lp=setInterval(()=>{if(gs!=='win'){clearInterval(lp);return;}spawnCP();},120);
}
function spawnCP(){const p=document.createElement('div');p.className='crp';const sz=4+Math.random()*10,dur=1.5+Math.random()*2;const col=['#f0c040','#ffffff','#80ffaa','#fffde0','#d4a0ff','#ffcc66'][ri(6)];p.style.cssText=`left:${10+Math.random()*80}%;bottom:${20+Math.random()*40}%;width:${sz}px;height:${sz}px;background:${col};box-shadow:0 0 ${sz}px ${col};animation-duration:${dur}s;animation-delay:${Math.random()*.5}s;`;ceEl.appendChild(p);setTimeout(()=>{try{p.remove();}catch(e){};},(dur+.5)*1000);}

// ══ GAME OVER ══
function gameOver(){gs='gameover';stopMus();if(score>best)best=score;document.getElementById('osc').textContent=score;document.getElementById('bsc').textContent=best;document.getElementById('os').style.display='flex';}

// ══ GAME LOOP ══
function loop(){
  if(gs!=='playing')return;
  frm++;score++;spd=2.5+score/600;

  // 배경 시차
  pyrOff+=spd*.04;
  bls.forEach(l=>l.style.transform=`translateX(-${pyrOff}px)`);

  // 스테이지 전환
  const ns=score<1000?0:score<2000?1:score<3000?2:score<4000?3:4;
  if(ns!==stg)setStage(ns);

  // 물리
  vy+=G;py-=vy;
  if(py<=0){py=0;vy=0;jl=2;}

  // 슬라이드 홀드 체크
  if(slid&&!(keys['ArrowDown']||keys['KeyS']||mob.sld))endSlide();

  // 플레이어 위치
  const ch=gc.offsetHeight;
  player.style.left=px+'px';
  player.style.bottom=(LY[lane]+py/ch*100)+'%';
  player.style.opacity=(inv>0&&Math.floor(inv/5)%2===0)?'0.3':'1';
  if(hasPow)player.classList.add('powered');else player.classList.remove('powered');
  if(frm%8===0&&py===0)spawnDust(px+8);

  // 타이머
  if(inv>0)inv--;
  const canHit=inv<=0&&!hasPow;
  if(hasPow){powT--;gpT++;if(gpT%3===0)spawnGP();if(powT<=0){hasPow=false;hideGod();}}
  if(gT>0&&--gT===0){const t=geEl.querySelector('.gtx');if(t)t.style.opacity='0';}

  // 재앙
  if(!plagOn&&!bossOn&&score>=nPlag){trigPlague();nPlag=score+400+ri(250);}
  if(plagOn){plagT--;if(plagTy==='hail'&&frm%8===0)spawnHail();if(plagT<=0)endPlague();}

  // 보스
  if(!bossOn&&bIdx<BOSS_AT.length&&score>=BOSS_AT[bIdx]){bIdx++;startBoss();}
  if(bossOn)updBoss();

  // 장애물 스폰
  spT++;if(spT>=spI){spT=0;spI=Math.max(45,95-score/30);if(!bossOn&&plagTy!=='locust')spawnObs();}

  // 메추라기
  if(score>=nHeal){spawnHeal();nHeal=score+500+ri(400);}
  for(let i=heals.length-1;i>=0;i--){
    const h=heals[i];h.x-=spd;h.el.style.left=h.x+'px';
    if(h.x<-40){h.el.remove();heals.splice(i,1);continue;}
    if(h.x<px+28&&h.x+24>px+4){
      if(lives<3){lives=Math.min(3,lives+1);flash('#ffdd88');showBanner('🐦 메추라기! 체력 회복!');}
      else showBanner('🐦 메추라기! (체력 최대)');
      h.el.remove();heals.splice(i,1);
    }
  }

  // ── 충돌 ──
  const pL=px+6, pR=px+26;
  for(let i=obs.length-1;i>=0;i--){
    const o=obs[i];
    o.x-=spd+(o.boost||0);o.el.style.left=o.x+'px';
    if(o.x+o.w<0||o.x>window.innerWidth+120){o.el.remove();obs.splice(i,1);continue;}
    if(pL>=o.x+o.w-4||pR<=o.x+4)continue; // X 미스

    // 십자가 픽업 (레인/높이 무관)
    if(o.cross){hasPow=true;powT=300;gpT=0;o.el.remove();obs.splice(i,1);flash('#d4a0ff');showGod();continue;}

    // 메뚜기 천장
    if(o.locust){if(py>=o.thr&&canHit){lives--;inv=IDUR;flash('#aa8800');vy=8;if(lives<=0){gameOver();return;}}continue;}

    // 레인 체크
    if(o.lane>=0&&o.lane!==lane)continue;

    // Y 충돌
    if(py>=o.h)continue;
    if(slid&&o.slide)continue;

    if(canHit){lives--;inv=IDUR;o.el.remove();obs.splice(i,1);flash('#ff2200');vy=-4;if(lives<=0){gameOver();return;}}
  }

  // 보스 투사체
  for(let i=bBuls.length-1;i>=0;i--){
    const b=bBuls[i];b.x-=b.spd;b.el.style.left=b.x+'px';
    if(b.x+12<0){b.el.remove();bBuls.splice(i,1);continue;}
    if(pL<b.x+10&&pR>b.x+2&&lane===b.lane&&py<55&&canHit){lives--;inv=IDUR;flash('#ff2200');vy=-4;b.el.remove();bBuls.splice(i,1);if(lives<=0){gameOver();return;}}
  }

  if(score>=TARGET){showWin();return;}
  updHUD();
  raf=requestAnimationFrame(loop);
}

// ══ START GAME ══
function startGame(){
  if(raf)cancelAnimationFrame(raf);
  stopMus();
  gs='playing';score=0;lives=3;spd=2.5;frm=0;
  px=100;py=0;vy=0;jl=2;lane=0;slid=false;slidT=0;inv=0;
  hasPow=false;powT=0;gpT=0;gT=0;
  pyrOff=0;stg=-1;
  plagOn=false;plagT=0;plagTy='';nPlag=450;
  bossOn=false;bossX=0;bossP=0;bossT=0;bIdx=0;
  spT=0;spI=90;nHeal=600+ri(400);

  obs.forEach(o=>o.el.remove());obs=[];
  heals.forEach(h=>h.el.remove());heals=[];
  bBuls.forEach(b=>b.el.remove());bBuls=[];

  document.getElementById('ss').style.display='none';
  document.getElementById('os').style.display='none';
  ceEl.style.display='none';
  player.classList.remove('sliding','powered');player.style.opacity='1';
  pharaoh.style.display='none';baEl.classList.remove('on');
  poEl.style.opacity='0';poEl.className='';plblEl.style.opacity='0';
  geEl.style.display='none';

  bls.forEach((l,i)=>{l.style.transition='none';l.classList.toggle('vis',i===0);});
  bgEl.style.transition='none';bgEl.className='bg0';
  groundEl.style.transition='none';groundEl.className='g0';
  setTimeout(()=>{bls.forEach(l=>l.style.transition='');bgEl.style.transition='';groundEl.style.transition='';},100);

  setStage(0);updHUD();startMus();
  raf=requestAnimationFrame(loop);
}

document.getElementById('stb').addEventListener('click',startGame);
document.getElementById('rtb').addEventListener('click',startGame);
document.getElementById('cr').addEventListener('click',startGame);
</script>
