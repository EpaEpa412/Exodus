<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>출애굽기 — EXODUS</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#0a0500;font-family:'Crimson Text',serif;overflow:hidden;height:100vh;width:100vw;}
#gc{position:relative;width:100%;height:100%;overflow:hidden;}
#bg{position:absolute;inset:0;transition:background 2.5s ease;z-index:0;}
.bg0{background:linear-gradient(180deg,#1a0a00 0%,#2d1500 40%,#8b6914 70%,#c4960a 100%);}
.bg1{background:linear-gradient(180deg,#0d1a2e 0%,#1a2d1a 30%,#5c4a0a 65%,#8b7020 100%);}
.bg2{background:linear-gradient(180deg,#0a0a0a 0%,#1a1520 25%,#2a1a0a 50%,#4a3010 75%,#6a4820 100%);}
.bg3{background:linear-gradient(180deg,#1a0808 0%,#2d1010 30%,#5c2a0a 60%,#8a4a1a 80%,#a06020 100%);}
.bg4{background:linear-gradient(180deg,#0a0d1a 0%,#0d1a3a 35%,#1a3a6e 55%,#5c8020 75%,#8b7a1a 100%);}
.bgl{position:absolute;bottom:30%;left:0;right:0;opacity:0;transition:opacity 2.5s ease;will-change:transform;}
.bgl.vis{opacity:1;}
.pyr{position:absolute;bottom:0;border-style:solid;border-color:transparent;}
.p1{border-width:0 80px 120px 80px;border-bottom-color:#3d2000;left:5%;}
.p2{border-width:0 120px 180px 120px;border-bottom-color:#2a1500;left:18%;}
.p3{border-width:0 70px 100px 70px;border-bottom-color:#3d2000;right:8%;}
.p4{border-width:0 100px 150px 100px;border-bottom-color:#2a1500;right:20%;}
.rb{position:absolute;bottom:0;background:linear-gradient(160deg,#5a4a2a,#3a2a10);border-radius:40% 60% 0 0/60% 40% 0 0;}
.rb1{width:90px;height:55px;left:8%;}.rb2{width:140px;height:80px;left:25%;background:linear-gradient(160deg,#4a3a1a,#2a1a08);}
.rb3{width:70px;height:40px;right:15%;}.rb4{width:110px;height:65px;right:30%;background:linear-gradient(160deg,#4a3a1a,#2a1a08);}
.mt{position:absolute;bottom:0;background:linear-gradient(160deg,#2a1e14,#1a1008);border-radius:30% 70% 0 0/50% 50% 0 0;}
.mt1{width:200px;height:160px;left:10%;}.mt2{width:280px;height:220px;left:30%;background:linear-gradient(160deg,#1e1610,#0e0a06);}
.mt3{width:180px;height:140px;right:12%;}.mt4{width:240px;height:190px;right:28%;background:linear-gradient(160deg,#1e1610,#0e0a06);}
.lgtn{position:absolute;top:5%;left:48%;width:3px;height:60px;background:linear-gradient(180deg,#ffffaa,#ffff00,transparent);opacity:0;animation:lgF 3s ease-in-out infinite;}
@keyframes lgF{0%,85%,100%{opacity:0;}87%,92%{opacity:1;}89%,94%{opacity:.3;}}
.mh{position:absolute;bottom:0;border-radius:50% 50% 0 0/40% 40% 0 0;}
.mh1{width:300px;height:80px;left:5%;background:linear-gradient(180deg,#6a2a0a,#3a1808);}
.mh2{width:200px;height:55px;left:35%;background:linear-gradient(180deg,#7a3210,#4a2010);}
.mh3{width:260px;height:70px;right:8%;background:linear-gradient(180deg,#6a2a0a,#3a1808);}
.mf{position:absolute;bottom:0;width:8px;background:linear-gradient(180deg,#ff8800,#ff4400,#cc2200);border-radius:4px 4px 0 0;animation:mfF .3s ease-in-out infinite alternate;}
.mf1{height:40px;left:20%;}.mf2{height:55px;left:55%;}.mf3{height:35px;right:18%;}
@keyframes mfF{from{transform:scaleX(1);opacity:.8;}to{transform:scaleX(.7);opacity:1;}}
.clf{position:absolute;bottom:0;background:linear-gradient(180deg,#2a3a5a,#1a2a4a);border-radius:10px 30px 0 0;}
.cl1{width:180px;height:100px;left:5%;}.cl2{width:140px;height:75px;right:10%;background:linear-gradient(180deg,#1a2a4a,#0a1a3a);}
.wvb{position:absolute;bottom:0;height:30px;background:linear-gradient(180deg,#1a6699aa,#0a3d5c88);border-radius:50% 50% 0 0;animation:wvR 2s ease-in-out infinite alternate;}
.wv1{width:200px;left:20%;}.wv2{width:160px;left:45%;animation-delay:.6s;}.wv3{width:220px;right:5%;animation-delay:1.2s;}
@keyframes wvR{from{transform:scaleX(1) translateY(0);opacity:.6;}to{transform:scaleX(1.05) translateY(-5px);opacity:1;}}
#ground{position:absolute;bottom:0;left:0;right:0;height:30%;transition:background 2.5s ease;overflow:hidden;z-index:1;}
#ground::after{content:'';position:absolute;top:0;left:0;width:200%;height:6px;
  background:repeating-linear-gradient(90deg,#c4960a33 0px,#c4960a33 30px,transparent 30px,transparent 70px);
  animation:gS .4s linear infinite;}
@keyframes gS{from{transform:translateX(0);}to{transform:translateX(-70px);}}
.g0{background:linear-gradient(180deg,#8b6914 0%,#5c4008 40%,#3d2800 100%);}
.g1{background:linear-gradient(180deg,#6b5a1a 0%,#4a3a0a 40%,#2a2000 100%);}
.g2{background:linear-gradient(180deg,#4a3a2a 0%,#2a2018 40%,#1a1008 100%);}
.g3{background:linear-gradient(180deg,#7a3a1a 0%,#5a2810 40%,#3a1808 100%);}
.g4{background:linear-gradient(180deg,#3a5a2a 0%,#2a4020 40%,#1a2a10 100%);}
#sand{position:absolute;bottom:29%;left:0;right:0;height:12px;background:linear-gradient(90deg,transparent,#c4960a44,#f0c04066,#c4960a44,transparent);animation:sandS .6s linear infinite;z-index:2;}
@keyframes sandS{from{transform:translateX(0);}to{transform:translateX(-40px);}}
.star{position:absolute;background:#fff;border-radius:50%;animation:tw 2s infinite alternate;}
@keyframes tw{from{opacity:.3;}to{opacity:1;}}
#moon{position:absolute;top:8%;right:12%;width:50px;height:50px;background:radial-gradient(circle at 35% 35%,#fff8dc,#f0c040);border-radius:50%;box-shadow:0 0 30px #f0c04088,0 0 60px #f0c04044;animation:mG 3s ease-in-out infinite alternate;z-index:1;}
@keyframes mG{from{box-shadow:0 0 30px #f0c04088;}to{box-shadow:0 0 60px #f0c040cc;}}
#hud{position:absolute;top:0;left:0;right:0;padding:10px 18px;display:flex;justify-content:space-between;align-items:center;background:linear-gradient(180deg,#00000088,transparent);z-index:100;}
.ht{font-family:'Cinzel',serif;font-size:12px;color:#c4960a;letter-spacing:3px;}
.hs{font-family:'Cinzel',serif;font-size:18px;color:#f0c040;text-shadow:0 0 10px #f0c04088;}
.hl{font-size:16px;}
.hp{font-family:'Cinzel',serif;font-size:11px;color:#d4a0ff;display:none;animation:pp .5s ease-in-out infinite alternate;}
@keyframes pp{from{opacity:.7;}to{opacity:1;text-shadow:0 0 10px #d4a0ff;}}
#pbar{position:absolute;bottom:10px;left:16px;right:16px;z-index:100;}
.plbl{font-family:'Cinzel',serif;font-size:9px;color:#c4960a88;letter-spacing:1px;margin-bottom:3px;text-align:center;}
.ptrk{height:6px;background:#ffffff11;border-radius:3px;border:1px solid #c4960a33;overflow:hidden;}
.pfil{height:100%;background:linear-gradient(90deg,#c4960a,#f0c040,#80ffaa);border-radius:3px;transition:width .3s;box-shadow:0 0 8px #f0c04066;}
#player{position:absolute;width:32px;height:52px;z-index:10;}
#player.sliding{transform-origin:bottom center;transform:scaleY(.45) translateY(10px);transition:transform .08s ease-out;}
#player:not(.sliding){transition:transform .1s ease-out;}
.mr{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:22px;height:36px;background:linear-gradient(180deg,#e8d5a3,#d4b96a);border-radius:3px 3px 8px 8px;}
.mhd{position:absolute;top:0;left:50%;transform:translateX(-50%);width:16px;height:16px;background:#c4865a;border-radius:50%;}
.mbd{position:absolute;top:13px;left:50%;transform:translateX(-50%);width:12px;height:8px;background:#e8e0d0;border-radius:2px 2px 6px 6px;}
.mst{position:absolute;bottom:2px;right:-4px;width:4px;height:48px;background:linear-gradient(180deg,#8b5e1a,#5c3a0a);border-radius:2px;}
.sg{position:absolute;top:0;left:-4px;width:12px;height:12px;background:radial-gradient(circle,#80ffaa,transparent);border-radius:50%;animation:sgA 1.5s ease-in-out infinite;}
@keyframes sgA{0%,100%{opacity:.4;transform:scale(1);}50%{opacity:1;transform:scale(1.5);}}
#player.powered::after{content:'';position:absolute;top:-8px;left:-10px;width:52px;height:70px;background:radial-gradient(ellipse,#d090ff66 0%,#8040cc33 40%,transparent 70%);border-radius:50%;animation:au .3s ease-in-out infinite alternate;z-index:-1;}
@keyframes au{from{transform:scale(1);opacity:.7;}to{transform:scale(1.15);opacity:1;}}
.obs{position:absolute;z-index:8;}
.sh{position:absolute;top:-4px;left:50%;transform:translateX(-50%);width:16px;height:10px;background:#c4960a;border-radius:50% 50% 0 0;}
.sd{position:absolute;top:6px;left:50%;transform:translateX(-50%);width:14px;height:14px;background:#c4865a;border-radius:50%;}
.sb{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:20px;height:30px;background:linear-gradient(180deg,#8b1a00,#6b1200);border-radius:2px;}
.sp{position:absolute;top:4px;right:-6px;width:3px;height:44px;background:#8b5e1a;border-radius:1px;}
.spt{position:absolute;top:-6px;left:-2px;width:0;height:0;border-left:3px solid transparent;border-right:3px solid transparent;border-bottom:8px solid #c0c0c0;}
.swl,.swr{position:absolute;bottom:6px;width:18px;height:12px;background:#2a7a2a;border-radius:60% 0 0 40%;animation:scW .3s ease-in-out infinite alternate;}
.swl{left:-8px;transform-origin:right center;}.swr{right:-8px;border-radius:0 60% 40% 0;transform-origin:left center;animation-delay:.15s;}
.scb{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:30px;height:20px;background:radial-gradient(circle at 40% 40%,#1a5c1a,#0a3a0a);border-radius:50% 50% 40% 40%;box-shadow:0 0 8px #00aa0044;}
@keyframes scW{from{transform:rotateY(0);}to{transform:rotateY(30deg);}}
.sprj{position:absolute;height:5px;background:linear-gradient(90deg,#c0c0c0,#8b5e1a);border-radius:2px;z-index:8;}
.sprj::before{content:'';position:absolute;right:-8px;top:-4px;width:0;height:0;border-top:6px solid transparent;border-bottom:6px solid transparent;border-left:10px solid #c0c0c0;}
/* 십자가 */
.cw{position:absolute;width:30px;height:38px;z-index:15;}
.ci{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:30px;height:38px;animation:ciF .9s ease-in-out infinite alternate;}
.ci::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:8px;height:38px;background:linear-gradient(180deg,#fff8dc,#f0c040,#c4960a);border-radius:3px;box-shadow:0 0 12px #f0c040cc;}
.ci::after{content:'';position:absolute;top:10px;left:50%;transform:translateX(-50%);width:30px;height:8px;background:linear-gradient(90deg,#c4960a,#f0c040,#fff8dc,#f0c040,#c4960a);border-radius:3px;box-shadow:0 0 12px #f0c040cc;}
@keyframes ciF{from{transform:translateX(-50%) translateY(0) rotate(-3deg);filter:drop-shadow(0 0 8px #f0c040aa);}
  to{transform:translateX(-50%) translateY(-7px) rotate(3deg);filter:drop-shadow(0 0 18px #fffde0);}}
/* 메추라기 */
.qi{position:absolute;width:24px;height:20px;animation:qiF .9s ease-in-out infinite alternate;z-index:15;}
@keyframes qiF{from{transform:translateY(0);}to{transform:translateY(-6px);}}
/* 파라오 */
#pharaoh{position:absolute;bottom:30%;width:70px;height:90px;z-index:20;display:none;}
.phc{position:absolute;top:0;left:50%;transform:translateX(-50%);width:30px;height:18px;background:linear-gradient(180deg,#f0c040,#c4960a);clip-path:polygon(0% 100%,20% 0%,40% 60%,60% 0%,80% 60%,100% 0%,100% 100%);}
.phh{position:absolute;top:16px;left:50%;transform:translateX(-50%);width:28px;height:28px;background:#c4865a;border-radius:50%;border:2px solid #f0c040;}
.phb{position:absolute;top:42px;left:50%;transform:translateX(-50%);width:38px;height:40px;background:linear-gradient(180deg,#8b1a00,#5a0a00);border-radius:4px 4px 12px 12px;}
.phf{position:absolute;top:36px;right:2px;width:4px;height:30px;background:#c4960a;border-radius:2px;transform-origin:top center;animation:phfS .6s ease-in-out infinite alternate;}
@keyframes phfS{from{transform:rotate(-30deg);}to{transform:rotate(30deg);}}
/* 파라오 경고 */
#ba{position:absolute;inset:0;z-index:180;display:none;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
#ba.on{display:flex;animation:baB .25s step-end infinite;}
@keyframes baB{0%,100%{background:rgba(180,0,0,.18);}50%{background:rgba(180,0,0,.38);}}
.ab{position:absolute;inset:0;border:6px solid #ff2200;animation:abP .3s step-end infinite;pointer-events:none;}
@keyframes abP{0%,100%{opacity:1;}50%{opacity:.2;}}
.at{font-family:'Cinzel',serif;font-size:clamp(20px,5vw,36px);color:#ff2200;letter-spacing:6px;text-shadow:0 0 30px #ff2200,0 0 60px #ff000088;animation:atP .4s ease-in-out infinite alternate;}
@keyframes atP{from{transform:scale(1);opacity:.85;}to{transform:scale(1.08);opacity:1;}}
.as{font-family:'Cinzel',serif;font-size:clamp(10px,2vw,14px);color:#ffaa88;letter-spacing:4px;margin-top:10px;text-shadow:0 0 10px #ff4400;}
/* 재앙 */
#po{position:absolute;inset:0;pointer-events:none;z-index:88;opacity:0;transition:opacity .4s;}
#po.pl{background:rgba(80,60,0,.32);}#po.pd{background:rgba(0,0,0,.72);}#po.ph{background:rgba(180,220,255,.18);}
#plbl{position:absolute;top:15%;left:50%;transform:translateX(-50%);font-family:'Cinzel',serif;font-size:13px;color:#ffddaa;letter-spacing:2px;text-shadow:0 0 12px #ff6600,0 2px 4px #000;background:#00000066;padding:6px 16px;border-radius:20px;border:1px solid #ff660044;opacity:0;pointer-events:none;z-index:96;white-space:nowrap;transition:opacity .4s;}
/* 배너 */
#sb{position:absolute;top:20%;left:50%;transform:translateX(-50%);font-family:'Cinzel',serif;font-size:14px;color:#f0c040;letter-spacing:4px;text-shadow:0 0 20px #f0c040;text-align:center;opacity:0;pointer-events:none;z-index:95;white-space:nowrap;transition:opacity .5s;}
/* 레인 인디케이터 */
#li{position:absolute;left:14px;z-index:99;display:flex;flex-direction:column;gap:6px;}
.ld{width:7px;height:7px;border-radius:50%;background:#c4960a44;transition:all .15s;}
.ld.on{background:#f0c040;transform:scale(1.4);}
/* 하나님 이펙트 */
#ge{position:absolute;inset:0;pointer-events:none;z-index:90;display:none;}
.gr{position:absolute;top:0;left:50%;transform:translateX(-50%);width:100%;height:70%;background:conic-gradient(from 260deg at 50% 0%,transparent 0deg,#d090ff33 8deg,transparent 14deg,transparent 22deg,#a060cc44 28deg,transparent 34deg,transparent 46deg,#d4a0ff33 50deg,transparent 56deg,transparent 64deg,#d090ff44 70deg,transparent 76deg,transparent 90deg,#a060cc33 96deg,transparent 100deg);animation:grA 4s linear infinite;opacity:0;}
@keyframes grA{from{transform:translateX(-50%) rotate(0);opacity:1;}80%{opacity:1;}to{transform:translateX(-50%) rotate(20deg);opacity:.6;}}
.gha{position:absolute;top:5%;left:50%;transform:translateX(-50%);width:120px;height:120px;background:radial-gradient(circle,#d4a0ffff 0%,#8040cc99 30%,#6030aa44 60%,transparent 80%);border-radius:50%;animation:ghaP .8s ease-in-out infinite alternate;}
@keyframes ghaP{from{transform:translateX(-50%) scale(1);}to{transform:translateX(-50%) scale(1.3);}}
.gtx{position:absolute;top:10%;left:50%;transform:translateX(-50%);font-family:'Cinzel',serif;font-size:13px;color:#d4a0ff;letter-spacing:4px;text-shadow:0 0 20px #a060ff,0 0 40px #8040cc;white-space:nowrap;animation:gtF .4s ease-in-out infinite alternate;}
@keyframes gtF{from{opacity:.8;}to{opacity:1;text-shadow:0 0 30px #d4a0ff,0 0 60px #a060ff;}}
.gp{position:absolute;width:4px;height:4px;background:#a060ff;border-radius:50%;animation:gpF linear forwards;box-shadow:0 0 6px #a060ff;}
@keyframes gpF{0%{transform:translateY(0) scale(1);opacity:1;}100%{transform:translateY(200px) scale(0);opacity:0;}}
/* 먼지/플래시 */
.dust{position:absolute;width:6px;height:6px;background:#c4960a44;border-radius:50%;animation:dF .6s ease-out forwards;pointer-events:none;z-index:5;}
@keyframes dF{from{transform:translateY(0) scale(1);opacity:.6;}to{transform:translateY(-15px) scale(2);opacity:0;}}
.flash{position:absolute;inset:0;opacity:0;z-index:300;pointer-events:none;animation:flA .3s ease-out forwards;}
@keyframes flA{0%{opacity:.8;}100%{opacity:0;}}
@keyframes hailFall{from{transform:translateY(0) rotate(15deg);opacity:1;}to{transform:translateY(100vh) rotate(15deg);opacity:.5;}}
/* 클리어 */
#ce{position:absolute;inset:0;z-index:400;display:none;overflow:hidden;}
#csl,#csr{position:absolute;bottom:0;width:50%;height:32%;background:linear-gradient(180deg,#1a8aaa,#0a4d6e,#062a40);z-index:5;}
#csl{left:0;animation:csL 2s cubic-bezier(.4,0,.2,1) .3s both;}
#csr{right:0;animation:csR 2s cubic-bezier(.4,0,.2,1) .3s both;}
@keyframes csL{from{transform:translateX(50%);}to{transform:translateX(0);}}
@keyframes csR{from{transform:translateX(-50%);}to{transform:translateX(0);}}
#cry{position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:200%;height:140%;background:conic-gradient(from 270deg at 50% 0%,transparent 0deg,#fff8c033 5deg,transparent 10deg,transparent 18deg,#f0c04044 22deg,transparent 27deg,transparent 35deg,#fffde055 38deg,transparent 43deg,transparent 52deg,#fff8c033 55deg,transparent 60deg,transparent 68deg,#f0c04044 72deg,transparent 77deg,transparent 85deg,#fffde055 88deg,transparent 93deg,transparent 100deg);animation:cryA 4s linear infinite;}
@keyframes cryA{from{transform:translateX(-50%) rotate(0);}to{transform:translateX(-50%) rotate(360deg);}}
#crl{position:absolute;top:0;left:50%;transform:translateX(-50%);width:300px;height:100%;background:linear-gradient(180deg,#fffde0ff 0%,#f0c04088 30%,transparent 70%);animation:crlA 1.5s ease-in-out infinite alternate;}
@keyframes crlA{from{opacity:.7;width:200px;}to{opacity:1;width:360px;}}
#crb{position:absolute;top:-120px;left:50%;transform:translateX(-50%);width:120px;height:120px;background:radial-gradient(circle,#ffffff 0%,#fff8c0 30%,#f0c040 60%,transparent 80%);border-radius:50%;box-shadow:0 0 60px #fffde0,0 0 120px #f0c04088;animation:crbA 2.5s cubic-bezier(.2,0,.4,1) forwards;}
@keyframes crbA{from{top:-120px;opacity:0;transform:translateX(-50%) scale(.3);}60%{opacity:1;}to{top:8%;opacity:1;transform:translateX(-50%) scale(1);}}
#crt{position:absolute;top:26%;left:50%;transform:translateX(-50%);text-align:center;opacity:0;animation:crtA 1s ease-out 2.2s forwards;}
@keyframes crtA{from{opacity:0;transform:translateX(-50%) translateY(20px);}to{opacity:1;transform:translateX(-50%) translateY(0);}}
.ctl{font-family:'Cinzel',serif;font-size:clamp(22px,5vw,38px);color:#fff8dc;letter-spacing:8px;text-shadow:0 0 30px #f0c040,0 0 60px #c4960a88;display:block;margin-bottom:12px;}
.ctv{font-family:'Crimson Text',serif;font-style:italic;font-size:clamp(11px,2vw,15px);color:#f0c040cc;letter-spacing:1px;max-width:460px;line-height:1.8;display:block;padding:0 20px;}
#cbn{position:absolute;bottom:12%;left:50%;transform:translateX(-50%);opacity:0;animation:crtA .8s ease-out 4.2s forwards;}
.crp{position:absolute;border-radius:50%;animation:crpA linear forwards;pointer-events:none;}
@keyframes crpA{from{transform:translateY(0) scale(1);opacity:1;}to{transform:translateY(-60vh) scale(0);opacity:0;}}
/* 화면 */
.screen{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200;background:radial-gradient(ellipse at center,#1a0a0088,#0a050099);backdrop-filter:blur(3px);}
.screen h1{font-family:'Cinzel',serif;font-size:32px;color:#f0c040;text-shadow:0 0 30px #f0c040,0 0 60px #c4960a;letter-spacing:6px;margin-bottom:8px;text-align:center;}
.screen h2{font-family:'Cinzel',serif;font-size:16px;color:#c4960a;letter-spacing:4px;margin-bottom:28px;text-align:center;}
.screen p{font-size:14px;color:#d4b96a99;letter-spacing:1px;margin-bottom:5px;text-align:center;}
.btn{font-family:'Cinzel',serif;font-size:13px;color:#0a0500;background:linear-gradient(135deg,#f0c040,#c4960a);border:none;padding:12px 36px;border-radius:2px;cursor:pointer;letter-spacing:3px;margin-top:18px;transition:all .2s;}
.btn:hover{transform:scale(1.05);box-shadow:0 0 20px #f0c04088;}
.verse{font-style:italic;font-size:11px;color:#c4960a66;max-width:360px;text-align:center;line-height:1.7;margin-top:14px;padding:0 20px;}
/* 모바일 */
#mc{position:absolute;bottom:28px;left:0;right:0;display:none;justify-content:space-between;padding:0 18px;z-index:150;}
.mb{width:58px;height:58px;background:#ffffff22;border:2px solid #c4960a44;border-radius:50%;font-size:20px;display:flex;align-items:center;justify-content:center;cursor:pointer;user-select:none;-webkit-user-select:none;}
#msld{font-size:12px;font-family:'Cinzel',serif;letter-spacing:0;}
