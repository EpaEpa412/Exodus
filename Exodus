  <!-- 파라오 -->
  <div id="pharaoh"><div class="phc"></div><div class="phh"></div><div class="phb"></div><div class="phf"></div></div>
  <!-- 파라오 경고 -->
  <div id="ba"><div class="ab"></div><div class="at">⚠ 파라오가 나타났다 ⚠</div><div class="as">PHARAOH APPROACHES</div></div>
  <!-- 하나님 이펙트 -->
  <div id="ge"><div class="gr"></div><div class="gha"></div><div class="gtx">✝ 십자가의 힘이 임하다</div></div>
  <!-- 배너 -->
